{{ 'section-behind-the-seams.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="behind-the-seams section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
  style="--bts-bg: {{ section.settings.background_color | default: '#fdfaf6' }};"
>
  <div class="behind-the-seams__inner page-width">
    <header class="behind-the-seams__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="behind-the-seams__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="behind-the-seams__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <div class="behind-the-seams__intro rte">{{ section.settings.intro }}</div>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <ul class="behind-the-seams__grid list-unstyled" role="list">
        {%- for block in section.blocks -%}
          <li class="behind-the-seams__cell" {{ block.shopify_attributes }}>
            <div class="behind-the-seams__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '300, 500, 700, 900, 1200',
                    sizes: '(min-width: 990px) 32vw, (min-width: 750px) 45vw, 90vw',
                    alt: block.settings.image.alt | default: block.settings.title,
                    class: 'behind-the-seams__image'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg behind-the-seams__image' }}
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="behind-the-seams__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <div class="behind-the-seams__description rte">{{ block.settings.description }}</div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Behind the seams",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fdfaf6"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "BEHIND THE SEAMS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Artisan Hand-Painting"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro paragraph",
      "default": "<p>Every stroke is painted by hand by our master artisans in Jaipur, taking over 48 hours to complete a single saree. We use eco-friendly dyes on the finest pure silk organza.</p>"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Pure Organza"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Lightweight and airy texture, creating an ethereal look perfect for summer weddings.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Behind the seams",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "100% Pure Organza",
            "description": "<p>Lightweight and airy texture, creating an ethereal look perfect for summer weddings.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Hand-Painted Art",
            "description": "<p>Delicate sunflowers scattered across the drape, each unique and imperfectly perfect.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Eco-Conscious",
            "description": "<p>We believe in slow fashion. Crafted responsibly with minimal waste and ethical wages.</p>"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product", "page", "index"]
  }
}
{% endschema %}
