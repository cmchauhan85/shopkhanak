{{ 'section-trust-markers.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #TrustMarkers-{{ section.id }} {
    --trust-markers-bg: {{ section.settings.background_color }};
    --trust-markers-icon: {{ section.settings.icon_color }};
    --trust-markers-title: {{ section.settings.title_color }};
    --trust-markers-subtext: {{ section.settings.subtext_color }};
  }
{%- endstyle -%}

<div id="TrustMarkers-{{ section.id }}" class="trust-markers section-{{ section.id }}-padding">
  <div class="trust-markers__container page-width">
    <div class="trust-markers__list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'trust_marker' -%}
            <div class="trust-markers__item" {{ block.shopify_attributes }}>
              <span class="trust-markers__icon" aria-hidden="true">
                {%- render 'trust-marker-icon', icon: block.settings.icon -%}
              </span>
              <div class="trust-markers__content">
                {%- if block.settings.title != blank -%}
                  <span class="trust-markers__title">{{ block.settings.title | escape }}</span>
                {%- endif -%}
                {%- if block.settings.subtext != blank -%}
                  <span class="trust-markers__subtext">{{ block.settings.subtext | escape }}</span>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Trust markers",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#f8f6f3"
      },
      {
        "type": "color",
        "id": "icon_color",
        "label": "Icon color",
        "default": "#5c4033"
      },
      {
        "type": "color",
        "id": "title_color",
        "label": "Title color",
        "default": "#333333"
      },
      {
        "type": "color",
        "id": "subtext_color",
        "label": "Subtext color",
        "default": "#6b6b6b"
      }, {
        "type": "header",
        "content": "Section padding"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Top padding",
        "default": 24
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Bottom padding",
        "default": 24
      }
    ],
    "blocks": [
      {
        "type": "trust_marker",
        "name": "Trust marker",
        "settings": [
          {
            "type": "select",
            "id": "icon",
            "label": "Icon",
            "options": [
              {
                "value": "lock",
                "label": "Secure / Lock"
              },
              {
                "value": "return",
                "label": "Returns"
              },
              {
                "value": "heart",
                "label": "Heart / Quality"
              },
              {
                "value": "truck",
                "label": "Shipping / Truck"
              }, {
                "value": "shield",
                "label": "Shield"
              }
            ],
            "default": "lock"
          }, {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Secure Checkout"
          }, {
            "type": "text",
            "id": "subtext",
            "label": "Subtext",
            "default": "ENCRYPTED PAYMENTS"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Trust markers",
        "blocks": [
          {
            "type": "trust_marker",
            "settings": {
              "icon": "lock",
              "title": "Secure Checkout",
              "subtext": "ENCRYPTED PAYMENTS"
            }
          }, {
            "type": "trust_marker",
            "settings": {
              "icon": "return",
              "title": "7-Day Easy Returns",
              "subtext": "NO QUESTIONS ASKED"
            }
          }, {
            "type": "trust_marker",
            "settings": {
              "icon": "heart",
              "title": "Handcrafted Quality",
              "subtext": "ARTISANAL EXCELLENCE"
            }
          }
        ]
      }
    ]
  }
{% endschema %}